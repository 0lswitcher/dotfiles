{
        "layer": "top",
        "output": ["DP-2", "DP-1", "HDMI-A-1"],
        "position": "top",
        "spacing": 0,
        "reload_style_on_change": true,
        "height": 36,
        "margin": 0,        
        "modules-left": [
            "hyprland/workspaces",
            "group/shortcuts"
        ],        
        "modules-center": [
            "group/left-drawer",
            "clock",
            "group/tools"
        ],
        "modules-right": [
            "group/system-tray",
            "custom/notifications",
            "group/performance",
            "group/sound",
            "group/connections",
            "group/power"
        ],


 // LEFT MODULES

	    "group/shortcuts": {
	        "orientation": "inherit",
            "drawer": {
                "transition-duration": 1000,
                "children-class": "not-power",
                "transition-left-to-right": false,
            },
	        "modules": [
                "hyprland/window",
                "custom/terminal",
                "custom/sunshine",
                "custom/firefox",
                "custom/spotify",
                "custom/discord",
                "custom/neovide",
                "custom/vscode",
                "custom/spacer",                
                "custom/obsidian-vault",
                "custom/obsidian-tome42",
                "custom/obsidian-dotfiles",                
                "custom/spacer",
                "custom/steam",
                "custom/heroic",
                "custom/beamng",
                "custom/minecraft",
                "custom/spacer",
                "custom/tome42",
                "custom/bashrc",
                "custom/spacer",
	        ]
	    },

        "custom/spacer": {
            "format": "|",
            "tooltip": false
        },



        "custom/terminal": {
            "format": " яТЙ ",
            "on-click": "foot -f 'JetBrainsMono Nerd Font:size=12'",
            "tooltip-format": "foot terminal"
        },

        "custom/sunshine": {
            "format": " яФв ",
            "on-click": "foot sunshine; firefox --new-tab https://localhost:47990/",
            "tooltip-format": "sunshine host"
        },             
        
        "custom/firefox": {
            "format": " ґ░И╣",
            "on-click": "firefox",
            "tooltip-format": "firefox"
        },
        
        "custom/spotify": {
            "format": " яЖ╝ ",
            "on-click": "com.spotify.Client",
            "tooltip-format": "spotify"
        },

        "custom/discord": {
            "format": " яЗ┐ ",
            "on-click": "vesktop",
            "tooltip-format": "discord"
        },

        "custom/neovide": {
        	"format": " юЪо<span>\u2009</span>",
        	"on-click": "neovide",
        	"tooltip-format": "neovide"
        },
        
        "custom/vscode": {
            "format": " ґ░иЮ ",
            "on-click": "codium",
            "tooltip-format": "open source vscode"
        },

        "custom/obsidian-vault": {
            "format": " <sub>ювУ</sub>яФС ",
            "on-click": "xdg-open 'obsidian://open?vault=vault'",
            "tooltip-format": "obsidian vault"
        },

        "custom/obsidian-tome42": {
            "format": " <sub>ювУ</sub>ю║╛ ",
            "on-click": "xdg-open 'obsidian://open?vault=tome42'",
            "tooltip-format": "obsidian Tome42 repo"
        },

        "custom/obsidian-dotfiles": {
            "format": " <sub>ювУ</sub>ґ░Ье ",
            "on-click": "xdg-open 'obsidian://open?vault=dotfiles'",
            "tooltip-format": "obsidian dotfiles repo"
        },   

        "custom/steam": {
            "format": " яЖ╢ ",
            "on-click": "steam",
            "tooltip-format": "steam"
        },

        "custom/heroic": {
            "format": " ґ▒в╛ ",
            "on-click": "foot --hold heroic", 
            "tooltip-format": "heroic"
        },

        "custom/beamng": {
        	"format": "<span>\u2008</span><span font='12'>ґ░УФ</span><span>\u2008</span>",
        	"on-click": "~/Desktop/BeamNG.drive.desktop",
        	"tooltip-format": "BeamNG.drive"
        },

        "custom/minecraft": {
            "format": " ґ░Н│ ",
            "on-click": "prismlauncher",
            "tooltip-format": "minecraft"
        },

        "custom/tome42": {
            "format": " ю║╛ ",
            "on-click": "firefox --new-window http://192.168.254.130:6875/shelves/tome42-private",
            "tooltip-format": "Tome42"
        },        

        "custom/bashrc": {
            "format": "<span font='16'> ґ▒ЖГ </span>",
            "on-click": "firefox --new-window https://github.com/0lswitcher/dotfiles/blob/main/dots/bash/.bashrc_shared",
            "tooltip-format": "Globally shared .bashrc sourced from GitHub"
        },   

        "hyprland/workspaces": {
            "format": "<sub>{icon}</sub>{windows}",
            "format-icons": {
                "active":  "яЖТ",
                "default": "яЖТ",
                "empty":   "яДМ"
            },
            "active-only": false,
            "all-outputs": false,
            "persistent-only": false,
            "persistent-workspaces": [ ],
            //"persistent-workspaces": {
            //  "*": [ 1,2,3,4,5 ]
            //  "DP-2":     [ 1,2,3 ], // left monitor
            //  "DP-1":     [ 4,5,6 ], // center monitor
            //  "HDMI-A-1": [ 7,8,9 ], // right monitor            
            //},
            // to find name of program to rewrite, run hyprctl clients
            "window-rewrite": {
              "class<firefox> title<.*youtube.*>": "яЕк", 
              "class<firefox> title<.*github.*>": "яВЫ",
              "class<firefox> title<.*r/.*>": "яЖв",
              "class<firefox> title<.*photopea.*>": "юЮ╕",
              "class<firefox> title<.*tome42.*>": "ю║╛",
              "class<firefox> title<.*neowiki.*>": "ю║╛",
              "class<firefox>": "яЙй",
              "class<obsidian> title<.*vault.*>": "яФС",
              "class<obsidian> title<.*tome42.*>": "ю║╛",
              "class<obsidian> title<.*dotfiles.*>": "ґ░Ье",
              "class<Spotify>": "яЖ╝",
              "class<feh>":     "яА╛",
              "class<steam>":   "яЖ╢",
              "class<heroic>":  "ґ▒в╛",
              "class<neovide":  "юЪо",
              "class<codium>":  "югЪ",
              "foot": "яТЙ",
              "vesktop": "яЗ┐",
            },
        },
        
       "hyprland/window": {
              /* ґ▒Юй яВд яД╕  ю░Р */
            "format": " ю░Р  {}",
            "max-length": 50,
            "separate-outputs": true,
            "icon": false,
            "icon-size": 14,
            "offscreen-css" : true,
            "offscreen-css-text": "(inactive)",
          //  "rewrite":{
          //    "(.*) тАФ Mozilla Firefox": "ґ░И╣ "
          //  }
       },







 // CENTER MODULES

	    "group/left-drawer": {
	        "orientation": "inherit",
                "drawer": {
                    "transition-duration": 500,
                    "children-class": "not-power",
                    "transition-left-to-right": true,
                },
	        "modules": [
                "custom/larrow",
                "custom/spacer",
                "custom/spicetify-apply",
                "custom/spicetify-restore",
                "custom/spacer"
	        ]
	    },

        "custom/larrow": {
        /*  " ґ░еУ ю╗К  яГЩ яДД "  */
            "format": " ґ░еУ ",
            "tooltip": false
        },

        "custom/spicetify-apply": {
            "format": " яЖ╝ яАМ ",
            "on-click": "foot spicetify apply && sleep 2s && com.spotify.Client",
            "tooltip-format": "enable spicetify theme"
        },

        "custom/spicetify-restore": {
            "format": " яЖ╝ яАН ",
            "on-click": "foot spicetify restore && sleep 2s && com.spotify.Client",
            "tooltip-format": "disable spicetify theme"
        },

        "clock": {
            "format": "{:%I:%M:%S %p}",
            "interval": 1,
            "tooltip": true,
            "tooltip-format": "<tt>{calendar}</tt>",
            "calendar": {
                "format": {
                    "today": "<span color='#4169E1'><b>{}</b></span>"
                }
            },
            "actions": {
                "on-click-right": "shift_down",
                "on-click": "shift_up",
            }
        },


	    "group/tools": {
	        "orientation": "inherit",
            "drawer": {
                "transition-duration": 500,
                "children-class": "not-power",
                "transition-left-to-right": false,
            },
	        "modules": [
                "custom/rarrow",
                "custom/spacer",
                "custom/waypaper",
                "custom/random-background",
                "custom/swww",
                "custom/wp2theme",
                "custom/pywal",
                "custom/colorpicker",
                "custom/reload",
                "custom/spacer",
	        ]
	    },

        "custom/rarrow": {
        /*  " ґ░еУ ю╗К  яГЪ яДЕ "  */
            "format": " ґ░еУ ",
            "tooltip": false
        },

        "custom/waypaper": {
            "format": " яА╛ ",
            "on-click": "waypaper",
            "tooltip-format": "change wallpaper w/ waypaper"
        },

        "custom/random-background": {
            "format": " яБ┤ ",
            "on-click": "foot bash ~/stuff/dev/bash/scripts/random-background.sh",
            "tooltip-format": "change to random wallpaper"
        },

        "custom/swww": {
            "format": " ґ░╕Й ",
            "on-click": "foot -T WallpaperPicker bash ~/stuff/dev/bash/scripts/background-picker.sh && wal -R",
            "tooltip-format": "change wallpaper"
        },

        "custom/wp2theme": {
            "format": " ю╣▓ ",
            "on-click": "bash ~/stuff/dev/bash/scripts/swww-as-theme.sh",
            "tooltip-format": "set colorscheme from wallpaper"
        },

        "custom/pywal": {
            "format": " яЗ╝ ",
            "on-click": "foot -T ThemePicker bash ~/stuff/dev/bash/scripts/theme-picker.sh & wal -R",
            "tooltip-format": "change theme"
        },

        "custom/colorpicker": {
            "format": " яЗ╗ ",
            "on-click": "foot -T ColorPicker --hold hyprpicker -a",
            "tooltip-format": "color picker"
        },

        "custom/reload": {
            "format": " яВ╢ ",
            "on-click": "foot pkill waybar && hyprctl dispatch exec waybar",
            "tooltip-format": "reload waybar"
        },







 // RIGHT MODULES

	    "group/system-tray": {
	        "orientation": "inherit",
                "drawer": {
                    "transition-duration": 500,
                    "children-class": "not-power",
                    "transition-left-to-right": false,
                },
	        "modules": [
                "custom/tray-leader",
                "tray",
                "custom/spacer",
	        ]
	    },

        "custom/tray-leader": {
            "format": "яБУ",
        },

        "tray": {
        	"icon-size": 18,
        	"spacing": 10,
        	"show-passive-items": true,
        },

        "custom/notifications": {
            "format": "яВв ",
            "on-click": "swaync-client -t",
            "tooltip-format": "notifications"
        },

	    "group/performance": {
	        "orientation": "inherit",
	        "drawer": {
	            "transition-duration": 500,
	            "transition-left-to-right": false,
	            "click-to-reveal": true,
	            "start-expanded": true,
	        },
	        "modules": [
	          "custom/pulse",
              "cpu",  
              "temperature",      
              "custom/spacer",        
              "custom/gpu", 
              "custom/gpu-temp",
              "custom/gpu-fan",
              "custom/spacer",
		      "memory",
		      "custom/spacer",
	        ]
	    },
      
        "custom/spacer": {
            "format": "|<span>\u2009</span>",
            "tooltip": false
        },

        "custom/pulse": {
        	"format": "<span>\u205f</span>яСй <span>\u200a</span>",
        	"tooltip": "hardware"
        },

        "cpu": {
            "format": " яТ╝ тАЙ{usage}%тАЙ ",
            "interval": 1
        },

        "custom/gpu": {
          "exec": "nvidia-smi --query-gpu=utilization.gpu --format=csv,noheader,nounits",
      //  "format": " ґ░во {}% ", // яДЬ
          "format": "<span>\u0020</span><span font='16'>ґ░во </span><span rise='2000'>{}%</span>тАЙ",
          "markup": true,
          "return-type": "",
          "interval": 1
        },

        "custom/gpu-temp": {
        	"exec": "nvidia-smi --query-gpu=temperature.gpu --format=csv,noheader,nounits",
        	"format": "  {icon} {text}┬░C ",
        	"format-icons": ["яЛЛ", "яЛК", "яЛЙ", "яЛИ", "яЛЗ"],  
        	"return-type": "",
        	"interval": 1
        },

/*
        "custom/gpu-fan": {
            "exec": "nvidia-smi --query-gpu=fan.speed --format=csv,noheader,nounits",
            "interval": 5,
            "format": " ю╛з {}%",
            "format-icons": ["ґ▒С░", "ю╛з", "ґ▒Сп" ],
            "tooltip": true,
            "tooltip-format": "NVIDIA GPU Fan Speed"
       },
*/

        "memory": {
            "format": " ю┐Е  {}% ",
            "interval": 1
        },

        "temperature": {
            "hwmon-path-abs": "/sys/devices/platform/coretemp.0/hwmon",
            "input-filename": "temp1_input",
            "interval": 1,
            "critical-threshold": 90,
            "warning-threshold": 78,
            "format": " {icon} {temperatureC}┬░C ",
            "format-icons": ["яЛЛ", "яЛЛ", "яЛК", "яЛЙ", "яЛИ", "яЛЗ"],            
            "format-critical": " {icon} {temperatureC}┬░C ",
        },

	    "group/sound": {
	        "orientation": "inherit",
            "drawer": {
                "transition-duration": 500,
                "transition-left-to-right": false,
                "click-to-reveal": true,
            },	        
	        "modules": [
                "pulseaudio",
                "cava"
	        ]
	    },

        "cava": {
            // "cava_config": "$XDG_CONFIG_HOME/cava/cava.conf",
            "framerate": 60,
            "autosens": 1,
            "sensitivity": 1,
            "bars": 16,
            "lower_cutoff_freq": 50,
            "higher_cutoff_freq": 10000,
            "sleep_timer": 4,
            "hide_on_silence": false,
           // "format_silent": "quiet",
            "method": "pulse",
            "source": "auto",
            "stereo": true,
            "reverse": false,
          //  "bar_width": 2,
          //  "bar_spacing": 53,
            "bar_delimiter": 32,
            "monstercat": false,
            "waves": false,
            "noise_reduction": 0.77,
            "input_delay": 2,
            "format-icons": ["тЦБ", "тЦВ", "тЦГ", "тЦД", "тЦЕ", "тЦЖ", "тЦЗ", "тЦИ" ],
            "on-click": "pavucontrol",
            "actions": {
                       "on-click-right": "mode"
                       }
        },

        "pulseaudio": {
            "format": " {icon} {volume}% ",
            "format-bluetooth": "{volume}% {icon}яКФ {format_source}",
            "format-bluetooth-muted": "яСж {icon}яКФ {format_source}",
            "format-muted": "яЪй {format_source}",
            "format-icons": {
                "headphone": "яАе ",
                "hands-free": "яЦР ",
                "headset": "яЦР ",
                "phone": "яВХ ",
                "portable": "яВХ ",
                "default": ["яАж", "яАз", "яАи "]
            },
           // "on-click": "pavucontrol"
        },
    
 	    "group/connections": {
	        "orientation": "inherit",
            "drawer": {
                "transition-duration": 500,
                "children-class": "not-power",
                "transition-left-to-right": false,
            },
	        "modules": [
            "network",
		    "bluetooth",
		    "custom/spacer",
		    "network#ip",
		    "custom/spacer",		    
	        ]
	    },
      
        "bluetooth": {
            "format-on": "<span font='12'> ґ░Вп </span>",
            "format-off": " BT-off ",
            "format-disabled": " ґ░В▓ ",
            "format-connected-battery": "{device_battery_percentage}% ґ░Вп",
            "format-alt": "{device_alias}ґ░Вп ",
            "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
            "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
            "tooltip-format-enumerate-connected": "{device_alias}\n{device_address}",
            "tooltip-format-enumerate-connected-battery": "{device_alias}\n{device_address}\n{device_battery_percentage}%",
            "on-click": "foot bluetui",
        },

        "network#ip": {
        	"format": " {ipaddr}/{cidr} ",
        },

        "network": {
            "format-wifi": "{icon} ",
            "format-ethernet":" ґ░ИА  <span alpha='50%'>|</span> яАЩ  {bandwidthDownBytes} ",
            "format-disconnected": " юмБ  ",
            "tooltip-format-disconnected": "Error  ",
            "tooltip-format-wifi": "{essid} ({signalStrength}%) {icon} ",
            "tooltip-format-ethernet": "{ifname} ЁЯЦз ",
            "on-click": "foot nmtui",
            /* BACKUP ICON: яЗл  ю╝Й  ю╜Д  ґ░ИА  ґ░ИБ ґ░ИВ */
            "format-icons": ["ґ░дл", "ґ░дЯ", "ґ░дв", "ґ░де", "ґ░ди",],  /*  
            "format-icons": ["ґ░в┐", "ґ░в╝", "ґ░в╜", "ґ░в╛",],       */
            "interval": 10,
        },

        "group/power": {
            "orientation": "inherit",
                "drawer": {
                    "transition-duration": 500,
                    "children-class": "not-power",
                    "transition-left-to-right": false,
                },
            "modules": [
                "custom/leader",
                "custom/lock",
                "custom/reboot",
                "custom/off"
            ]
        },

        "custom/leader": { 
            "format": "<span>\u2004</span>яМУ ",
            "tooltip":false
        },

        "custom/off": {
            "format": " тП╗ ",
            "on-click": "shutdown -h now",
            "tooltip-format": "shutdown"
        },

        "custom/reboot": {
            "format": " яАб ",
            "on-click": "shutdown -r now",
            "tooltip-format": "reboot"
        },

        "custom/lock": {
            "format": " яАг ",
            "on-click": "hyprctl dispatch exit",
            "tooltip-format": "lock"
        }

}

