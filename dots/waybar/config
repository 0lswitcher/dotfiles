{
        "layer": "top",
        "output": ["DP-2", "DP-1", "HDMI-A-1"],
        "position": "top",
        "spacing": 0,
        "reload_style_on_change": true,
        "height": 36,
        "margin": 0,        
        "modules-left": [
            "hyprland/workspaces",
            "group/shortcuts"
        ],        
        "modules-center": [
            "group/files",
            "clock",
            "group/tools"
        ],
        "modules-right": [
            "custom/notifications",
            "group/performance",
            "group/sound",
            "group/connections",
            "group/power"
        ],


 // LEFT MODULES

	    "group/shortcuts": {
	        "orientation": "inherit",
            "drawer": {
                "transition-duration": 1000,
                "children-class": "not-power",
                "transition-left-to-right": false,
            },
	        "modules": [
                "hyprland/window",
                "custom/terminal",
                "custom/sunshine",
                "custom/firefox",
                "custom/spotify",
                "custom/discord",
                "custom/neovide",
                "custom/vscode",
                "custom/spacer",                
                "custom/obsidian-vault",
                "custom/obsidian-tome42",
                "custom/obsidian-dotfiles",                
                "custom/spacer",
                "custom/steam",
                "custom/heroic",
                "custom/beamng",
                "custom/minecraft",
                "custom/spacer",
                "custom/tome42",
                "custom/bashrc",
                "custom/spacer",
	        ]
	    },

        "custom/spacer": {
            "format": "|",
            "tooltip": false
        },

/*
        "tray": {
        	"icon-size": 21,
        	"spacing": 10,
        },
*/

        "custom/terminal": {
            "format": "  ",
            "on-click": "foot -f 'JetBrainsMono Nerd Font:size=12'",
            "tooltip-format": "foot terminal"
        },

        "custom/sunshine": {
            "format": "  ",
            "on-click": "foot sunshine; firefox --new-tab https://localhost:47990/",
            "tooltip-format": "sunshine host"
        },             
        
        "custom/firefox": {
            "format": " 󰈹",
            "on-click": "firefox",
            "tooltip-format": "firefox"
        },
        
        "custom/spotify": {
            "format": "  ",
            "on-click": "com.spotify.Client",
            "tooltip-format": "spotify"
        },

        "custom/discord": {
            "format": "  ",
            "on-click": "vesktop",
            "tooltip-format": "discord"
        },

        "custom/neovide": {
        	"format": " <span>\u2009</span>",
        	"on-click": "neovide",
        	"tooltip-format": "neovide"
        },
        
        "custom/vscode": {
            "format": " 󰨞 ",
            "on-click": "codium",
            "tooltip-format": "open source vscode"
        },

        "custom/obsidian-vault": {
            "format": " <sub></sub> ",
            "on-click": "xdg-open 'obsidian://open?vault=vault'",
            "tooltip-format": "obsidian vault"
        },

        "custom/obsidian-tome42": {
            "format": " <sub></sub> ",
            "on-click": "xdg-open 'obsidian://open?vault=tome42'",
            "tooltip-format": "obsidian Tome42 repo"
        },

        "custom/obsidian-dotfiles": {
            "format": " <sub></sub>󰜥 ",
            "on-click": "xdg-open 'obsidian://open?vault=dotfiles'",
            "tooltip-format": "obsidian dotfiles repo"
        },   

        "custom/steam": {
            "format": "  ",
            "on-click": "steam",
            "tooltip-format": "steam"
        },

        "custom/heroic": {
            "format": " 󱢾 ",
            "on-click": "foot --hold heroic", 
            "tooltip-format": "heroic"
        },

        "custom/beamng": {
        	"format": "<span>\u2008</span><span font='12'>󰓔</span><span>\u2008</span>",
        	"on-click": "~/Desktop/BeamNG.drive.desktop",
        	"tooltip-format": "BeamNG.drive"
        },

        "custom/minecraft": {
            "format": " 󰍳 ",
            "on-click": "prismlauncher",
            "tooltip-format": "minecraft"
        },

        "custom/tome42": {
            "format": "  ",
            "on-click": "firefox --new-window http://192.168.254.130:6875/shelves/tome42-private",
            "tooltip-format": "Tome42"
        },        

        "custom/bashrc": {
            "format": "<span font='16'> 󱆃 </span>",
            "on-click": "firefox --new-window https://github.com/0lswitcher/dotfiles/blob/main/dots/bash/.bashrc_shared",
            "tooltip-format": "Globally shared .bashrc sourced from GitHub"
        },   

        "hyprland/workspaces": {
            "format": "<sub>{icon}</sub>{windows}",
            "format-icons": {
                "active":  "",
                "default": "",
                "empty":   ""
            },
            "active-only": false,
            "all-outputs": false,
            "persistent-only": false,
            "persistent-workspaces": [ ],
            //"persistent-workspaces": {
            //  "*": [ 1,2,3,4,5 ]
            //  "DP-2":     [ 1,2,3 ], // left monitor
            //  "DP-1":     [ 4,5,6 ], // center monitor
            //  "HDMI-A-1": [ 7,8,9 ], // right monitor            
            //},
            // to find name of program to rewrite, run hyprctl clients
            "window-rewrite": {
              "class<firefox> title<.*youtube.*>": "", 
              "class<firefox> title<.*github.*>": "",
              "class<firefox> title<.*r/.*>": "",
              "class<firefox> title<.*photopea.*>": "",
              "class<firefox> title<.*tome42.*>": "",
              "class<firefox> title<.*neowiki.*>": "",
              "class<firefox>": "",
              "class<obsidian> title<.*vault.*>": "",
              "class<obsidian> title<.*tome42.*>": "",
              "class<obsidian> title<.*dotfiles.*>": "󰜥",
              "class<Spotify>": "",
              "class<feh>":     "",
              "class<steam>":   "",
              "class<heroic>":  "󱢾",
              "class<neovide":  "",
              "class<codium>":  "",
              "foot": "",
              "vesktop": "",
            },
        },
        
       "hyprland/window": {
              /* 󱞩     */
            "format": "   {}",
            "max-length": 50,
            "separate-outputs": true,
            "icon": false,
            "icon-size": 14,
            "offscreen-css" : true,
            "offscreen-css-text": "(inactive)",
          //  "rewrite":{
          //    "(.*) — Mozilla Firefox": "󰈹 "
          //  }
       },







 // CENTER MODULES

	    "group/files": {
	        "orientation": "inherit",
                "drawer": {
                    "transition-duration": 500,
                    "children-class": "not-power",
                    "transition-left-to-right": true,
                },
	        "modules": [
                "custom/larrow",
                "custom/spacer",
                "custom/spicetify-apply",
                "custom/spicetify-restore",
                "custom/spacer"
	        ]
	    },

        "custom/larrow": {
        /*  " 󰥓     "  */
            "format": " 󰥓 ",
            "tooltip": false
        },

        "custom/spicetify-apply": {
            "format": "   ",
            "on-click": "foot spicetify apply && sleep 2s && com.spotify.Client",
            "tooltip-format": "enable spicetify theme"
        },

        "custom/spicetify-restore": {
            "format": "   ",
            "on-click": "foot spicetify restore && sleep 2s && com.spotify.Client",
            "tooltip-format": "disable spicetify theme"
        },

        "clock": {
            "format": "{:%I:%M:%S %p}",
            "interval": 1,   
            "tooltip": true,
            "tooltip-format": "<tt>{calendar}</tt>",
            "calendar": {
                "format": {
                    "today": "<span color='#4169E1'><b>{}</b></span>"
                }
            },
            "actions": {
                "on-click-right": "shift_down",
                "on-click": "shift_up"
            }
        },


	    "group/tools": {
	        "orientation": "inherit",
            "drawer": {
                "transition-duration": 500,
                "children-class": "not-power",
                "transition-left-to-right": false,
            },
	        "modules": [
                "custom/rarrow",
                "custom/spacer",
                "custom/waypaper",
                "custom/random-background",
                "custom/swww",
                "custom/wp2theme",
                "custom/pywal",
                "custom/colorpicker",
                "custom/reload",
                "custom/spacer",
	        ]
	    },

        "custom/rarrow": {
        /*  " 󰥓     "  */
            "format": " 󰥓 ",
            "tooltip": false
        },

        "custom/waypaper": {
            "format": "  ",
            "on-click": "waypaper",
            "tooltip-format": "change wallpaper w/ waypaper"
        },

        "custom/random-background": {
            "format": "  ",
            "on-click": "foot bash ~/stuff/dev/bash/scripts/random-background.sh",
            "tooltip-format": "change to random wallpaper"
        },

        "custom/swww": {
            "format": " 󰸉 ",
            "on-click": "foot -T WallpaperPicker bash ~/stuff/dev/bash/scripts/background-picker.sh & wal -R",
            "tooltip-format": "change wallpaper"
        },

        "custom/wp2theme": {
            "format": "  ",
            "on-click": "bash ~/stuff/dev/bash/scripts/swww-as-theme.sh",
            "tooltip-format": "set colorscheme from wallpaper"
        },

        "custom/pywal": {
            "format": "  ",
            "on-click": "foot -T ThemePicker bash ~/stuff/dev/bash/scripts/theme-picker.sh & wal -R",
            "tooltip-format": "change theme"
        },

        "custom/colorpicker": {
            "format": "  ",
            "on-click": "foot -T ColorPicker --hold hyprpicker -a",
            "tooltip-format": "color picker"
        },

        "custom/reload": {
            "format": "  ",
            "on-click": "foot pkill waybar && hyprctl dispatch exec waybar",
            "tooltip-format": "reload waybar"
        },







 // RIGHT MODULES

        "custom/notifications": {
            "format": " ",
            "on-click": "swaync-client -t",
            "tooltip-format": "notifications"
        },

	    "group/performance": {
	        "orientation": "inherit",
	        "drawer": {
	            "transition-duration": 500,
	            "transition-left-to-right": false,
	            "click-to-reveal": true,
	            "start-expanded": true,
	        },
	        "modules": [
	          "custom/pulse",
              "cpu",  
              "temperature",      
              "custom/spacer",        
              "custom/gpu", 
              "custom/gpu-temp",
              "custom/gpu-fan",
              "custom/spacer",
		      "memory",
		      "custom/spacer",
	        ]
	    },
      
        "custom/spacer": {
            "format": "|<span>\u2009</span>",
            "tooltip": false
        },

        "custom/pulse": {
        	"format": "<span>\u205f</span> <span>\u200a</span>",
        	"tooltip": "hardware"
        },

        "cpu": {
            "format": "   {usage}%  ",
            "interval": 1
        },

        "custom/gpu": {
          "exec": "nvidia-smi --query-gpu=utilization.gpu --format=csv,noheader,nounits",
      //  "format": " 󰢮 {}% ", // 
          "format": "<span>\u0020</span><span font='16'>󰢮 </span><span rise='2000'>{}%</span> ",
          "markup": true,
          "return-type": "",
          "interval": 1
        },

        "custom/gpu-temp": {
        	"exec": "nvidia-smi --query-gpu=temperature.gpu --format=csv,noheader,nounits",
        	"format": "  {icon} {}°C ",
        	"format-icons": ["", "", "", "", ""],  
        	"return-type": "",
        	"interval": 1
        },

/*
        "custom/gpu-fan": {
            "exec": "nvidia-smi --query-gpu=fan.speed --format=csv,noheader,nounits",
            "interval": 5,
            "format": "  {}%",
            "format-icons": ["󱑰", "", "󱑯" ],
            "tooltip": true,
            "tooltip-format": "NVIDIA GPU Fan Speed"
       },
*/

        "memory": {
            "format": "   {}% ",
            "interval": 1
        },

        "temperature": {
            "hwmon-path-abs": "/sys/devices/platform/coretemp.0/hwmon",
            "input-filename": "temp1_input",
            "interval": 1,
            "critical-threshold": 90,
            "warning-threshold": 78,
            "format": " {icon} {temperatureC}°C ",
            "format-icons": ["", "", "", "", "", ""],            
            "format-critical": " {icon} {temperatureC}°C ",
        },

	    "group/sound": {
	        "orientation": "inherit",
            "drawer": {
                "transition-duration": 500,
                "transition-left-to-right": false,
                "click-to-reveal": true,
            },	        
	        "modules": [
                "pulseaudio",
                "cava"
	        ]
	    },

        "cava": {
            // "cava_config": "$XDG_CONFIG_HOME/cava/cava.conf",
            "framerate": 60,
            "autosens": 1,
            "sensitivity": 1,
            "bars": 16,
            "lower_cutoff_freq": 50,
            "higher_cutoff_freq": 10000,
            "sleep_timer": 4,
            "hide_on_silence": false,
           // "format_silent": "quiet",
            "method": "pulse",
            "source": "auto",
            "stereo": true,
            "reverse": false,
          //  "bar_width": 2,
          //  "bar_spacing": 53,
            "bar_delimiter": 32,
            "monstercat": false,
            "waves": false,
            "noise_reduction": 0.77,
            "input_delay": 2,
            "format-icons": ["▁", "▂", "▃", "▄", "▅", "▆", "▇", "█" ],
            "on-click": "pavucontrol",
            "actions": {
                       "on-click-right": "mode"
                       }
        },

        "pulseaudio": {
            "format": " {icon} {volume}% ",
            "format-bluetooth": "{volume}% {icon} {format_source}",
            "format-bluetooth-muted": " {icon} {format_source}",
            "format-muted": " {format_source}",
            "format-icons": {
                "headphone": " ",
                "hands-free": " ",
                "headset": " ",
                "phone": " ",
                "portable": " ",
                "default": ["", "", " "]
            },
           // "on-click": "pavucontrol"
        },
    
 	    "group/connections": {
	        "orientation": "inherit",
            "drawer": {
                "transition-duration": 500,
                "children-class": "not-power",
                "transition-left-to-right": false,
            },
	        "modules": [
            "network",
		    "bluetooth",
		    "custom/spacer",
		    "network#ip",
		    "custom/spacer",		    
	        ]
	    },
      
        "bluetooth": {
            "format-on": "<span font='12'> 󰂯 </span>",
            "format-off": " BT-off ",
            "format-disabled": " 󰂲 ",
            "format-connected-battery": "{device_battery_percentage}% 󰂯",
            "format-alt": "{device_alias}󰂯 ",
            "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
            "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
            "tooltip-format-enumerate-connected": "{device_alias}\n{device_address}",
            "tooltip-format-enumerate-connected-battery": "{device_alias}\n{device_address}\n{device_battery_percentage}%",
            "on-click": "foot bluetui",
        },

        "network#ip": {
        	"format": " {ipaddr}/{cidr} ",
        },

        "network": {
            "format-wifi": "{icon} ",
            "format-ethernet":" 󰈀  <span alpha='50%'>|</span>   {bandwidthDownBytes} ",
            "format-disconnected": "   ",
            "tooltip-format-disconnected": "Error  ",
            "tooltip-format-wifi": "{essid} ({signalStrength}%) {icon} ",
            "tooltip-format-ethernet": "{ifname} 🖧 ",
            "on-click": "foot nmtui",
            /* BACKUP ICON:       󰈀  󰈁 󰈂 */
            "format-icons": ["󰤫", "󰤟", "󰤢", "󰤥", "󰤨",],  /*  
            "format-icons": ["󰢿", "󰢼", "󰢽", "󰢾",],       */
            "interval": 10,
        },

        "group/power": {
            "orientation": "inherit",
                "drawer": {
                    "transition-duration": 500,
                    "children-class": "not-power",
                    "transition-left-to-right": false,
                },
            "modules": [
                "custom/leader",
                "custom/lock",
                "custom/reboot",
                "custom/off"
            ]
        },

        "custom/leader": { 
            "format": "<span>\u2004</span> ",
            "tooltip":false
        },

        "custom/off": {
            "format": " ⏻ ",
            "on-click": "shutdown -h now",
            "tooltip-format": "shutdown"
        },

        "custom/reboot": {
            "format": "  ",
            "on-click": "shutdown -r now",
            "tooltip-format": "reboot"
        },

        "custom/lock": {
            "format": "  ",
            "on-click": "hyprctl dispatch exit",
            "tooltip-format": "lock"
        }

}

